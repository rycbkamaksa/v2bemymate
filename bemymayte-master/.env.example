# BEMYMATE Nuxt app — environment template.
# Copy to .env (local dev) or app.env (docker-compose) and fill in values.
# Nuxt 3 maps NUXT_* onto runtimeConfig and NUXT_PUBLIC_* onto runtimeConfig.public automatically.

# FACEIT OAuth client secret (server-only)
NUXT_CLIENT_SECRET=<faceit_client_secret>

# FACEIT Data API key (server-only, Bearer token)
NUXT_API_KEY=<faceit_data_api_key>

# MongoDB connection string (server-only)
NUXT_DB_URL=mongodb://<user>:<pass>@localhost:27017/

# FACEIT OAuth client id (exposed to client via runtimeConfig.public)
NUXT_PUBLIC_CLIENT_ID=<faceit_client_id>

# Socket.IO search server host (exposed to client)
NUXT_PUBLIC_SEARCH_HOST=localhost:5176

# Landing-only mode toggle (true = hide app behind landing)
NUXT_PUBLIC_LANDING_MODE=false
