# BEMYMATE Socket.IO search server — environment template.
# Copy to .env (local dev) or provide via docker-compose environment.

# MongoDB connection string (required, no default)
DB_URL=mongodb://<user>:<pass>@localhost:27017/

# Hostname of the main Nuxt app (used for server-to-server HTTP calls)
APP_HOST=localhost

# Runtime mode (development | production)
NODE_ENV=development
